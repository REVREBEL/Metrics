{
  "name": "revrebel-metrics",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx scripts/generate-registry.mjs && next dev",
    "build": "tsx scripts/generate-registry.mjs && next build",
    "create:registry": "tsx scripts/generate-registry.mjs",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "lint:fullreport": "node scripts/eslint-report.mjs --mode fullreport",
    "report:errorreport": "node scripts/eslint-report.mjs --mode errorreport",
    "report:fixqueue": "node scripts/eslint-report.mjs --mode fixqueue",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,md,mdx}\" --cache",
    "format:write": "prettier --write \"**/*.{js,jsx,ts,tsx,md,mdx}\" --cache",
    "sync:data": "tsx scripts/sync-data.ts all",
    "sync:ga4": "tsx scripts/sync-data.ts ga4",
    "sync:pace": "tsx scripts/sync-data.ts pace",
    "sync:pace:property": "tsx scripts/sync-data.ts pace-property",
    "sync:pace:segment": "tsx scripts/sync-data.ts pace-segment",
    "sync:pace:roomtype": "tsx scripts/sync-data.ts pace-roomtype",
    "sync:pace:pickup": "tsx scripts/sync-data.ts pace-segment-pickup",
    "sync:pace:derived": "tsx scripts/sync-data.ts pace-derived",
    "sync-custom-registry": "npx tsx scripts/sync-registry.ts",
    "icons:build": "node ./scripts/build-icons.mjs",
    "icons:build:index": "node ./scripts/generate-icons-index.mjs",
    "icons:build:all": "pnpm run icons:build && pnpm run icons:build:index",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .next *.tsbuildinfo",
    "clean:node_modules": "rm -rf .next node_modules *.tsbuildinfo",
    "knip": "knip"
  },
